pragma solidity 0.8.23;

import "@openzeppelin/contracts-upgradeable@4.9.0/token/ERC20/IERC20Upgradeable.sol";
import "@openzeppelin/contracts-upgradeable@4.9.0/security/ReentrancyGuardUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable@4.9.0/proxy/utils/Initializable.sol";
import "@openzeppelin/contracts-upgradeable@4.9.0/proxy/utils/UUPSUpgradeable.sol";
import "@openzeppelin/contracts-upgradeable@4.9.0/access/OwnableUpgradeable.sol";
import "@chainlink/contracts/src/v0.8/interfaces/AggregatorV3Interface.sol";

contract AmericanDigitalCurrency is Initializable, ReentrancyGuardUpgradeable, UUPSUpgradeable, OwnableUpgradeable {
    uint256 private constant INITIAL_MAX_SUPPLY = 1_000_000e18;
    uint256 private constant PRECISION = 10**18;
    uint256 private constant MIN_PURCHASE = 100e12;
    uint256 private constant SECONDS_PER_YEAR = 365 * 24 * 60 * 60;
    uint256 private constant BASE_NFT_YIELD = 10e16;
    uint256 private constant BASE_PASSIVE_YIELD = 5e16;
    uint256 private constant RESERVE_THRESHOLD = 80e16;
    uint256 private constant MAX_PAYMENT_CAP = 10e16;
    uint256 private constant MERCHANT_PAYMENT_FEE = 25e14;
    uint256 private constant MERCHANT_INCENTIVE_RATE = 2e16;
    uint256 private constant DAILY_REDEMPTION_LIMIT = 1000e18;
    uint256 private constant MERCHANT_BONUS = 10e18;
    uint256 private constant MAX_MERCHANT_BONUSES = 2000;
    uint256 private constant MAX_GAS_POOL = 20_000e6;
    uint256 private constant ORACLE_STALENESS_THRESHOLD = 1 hours;
    uint256 private constant MAX_SUPPORTED_STABLECOINS = 20;
    uint256 private constant MAX_NFT_SUPPLY = 100_000;
    uint256 private constant LOAN_MAX_DURATION = 90 days;
    uint256 private constant NFT_BASE_VALUE = 1e18;

    bytes4 private constant INTERFACE_ID_ERC165 = 0x01ffc9a7;
    bytes4 private constant INTERFACE_ID_ERC721 = 0x80ac58cd;

    IERC20Upgradeable public primaryStablecoin;
    AggregatorV3Interface public goldPriceFeed;
    address public treasury;

    mapping(address => uint256) public reserveBalances;
    address[] public supportedStablecoins;
    mapping(address => bool) public isSupportedStablecoin;
    mapping(address => uint256) public merchantIncentivePools;
    uint256 public gasSubsidyPool;
    uint256 public gasSubsidyRate = 5e17;
    uint256 public voucherIdCounter = 1;
    mapping(uint256 => uint256) public voucherAmounts;
    mapping(uint256 => address) public voucherStablecoin;
    mapping(address => uint256) public liquidityPool;
    mapping(address => uint8) public stablecoinDecimals;

    struct Stake { bool isStaked; uint256 stakeTime; uint256 amount; }
    struct P2PLoan {
        address lender;
        uint256 amount;
        uint256 interest;
        uint256 startTime;
        uint256 tokenId;
        bool repaid;
    }

    uint256 private _totalSupply;
    uint256 public tokenIdCounter = 1;
    uint256 public nftTotalSupply;
    uint256 public feePool;
    bool public paused;
    mapping(address => bool) public whitelistedMerchants;
    mapping(address => mapping(uint256 => uint256)) public dailyRedemptionVolume;
    mapping(address => uint256) public lastRedemptionReset;
    uint256 public merchantBonusClaimed;
    mapping(uint256 => Stake) public stakedNFTs;
    mapping(address => P2PLoan) public p2pLoans;
    mapping(uint256 => uint256) public nftMintTime;

    mapping(address => uint256) private _balances;
    mapping(uint256 => address) private _owners;
    mapping(address => uint256) private _nftBalances;
    mapping(address => mapping(address => uint256)) private _allowances;

    /// @dev NFT approval for individual tokens
    mapping(uint256 => address) private _nftApprovals;
    /// @dev NFT operator approvals (owner => operator => approved)
    mapping(address => mapping(address => bool)) private _operatorApprovals;
    /// @dev Base URI for NFT metadata
    string public baseTokenURI;

    string private _name = "American Digital Currency";
    string private _symbol = "ADC";

    event Purchased(address indexed buyer, uint256 stablecoinAmount, uint256 adcAmount, address stablecoin);
    event CertificateOfOwnership(address indexed owner, uint256 adcAmount, uint256 indexed tokenId);
    event Redemption(address indexed user, uint256 adcAmount, uint256 stablecoinValue);
    event MerchantPayment(address indexed from, address indexed to, uint256 amount, uint256 indexed tokenId);
    event NFTStaked(address indexed owner, uint256 indexed tokenId, uint256 amount);
    event NFTUnstaked(address indexed owner, uint256 indexed tokenId, uint256 reward);
    event GasSubsidyClaimed(address indexed user, uint256 amount);
    event MerchantAdded(address indexed merchant);
    event GiftVoucherCreated(uint256 indexed voucherId, address indexed from, address indexed to, uint256 amount);
    event VoucherRedeemed(uint256 indexed voucherId, address indexed user, uint256 amount);
    event SwapExecuted(address indexed user, uint256 adcAmount, uint256 stablecoinAmount, address stablecoin);
    event P2PLoanCreated(address indexed lender, address indexed borrower, uint256 amount, uint256 tokenId);
    event P2PLoanRepaid(address indexed borrower, address indexed lender, uint256 amount);
    event P2PLoanLiquidated(address indexed lender, address indexed borrower, uint256 indexed tokenId);
    event NFTRewardClaimed(address indexed owner, uint256 indexed tokenId, uint256 reward);
    event ContractUpgraded(address indexed newImplementation);
    event ReservesFunded(address indexed funder, uint256 amount, address stablecoin);
    event Approval(address indexed owner, address indexed spender, uint256 value);
    event LiquidityAdded(address indexed provider, address indexed stablecoin, uint256 amount);
    event TransferNoFee(address indexed from, address indexed to, uint256 amount);
    event MerchantBonusClaimed(address indexed merchant, uint256 amount);
    event PrimaryStablecoinUpdated(address indexed oldStablecoin, address indexed newStablecoin);
    event NFTTransfer(address indexed from, address indexed to, uint256 indexed tokenId);
    event NFTApproval(address indexed owner, address indexed approved, uint256 indexed tokenId);
    event NFTApprovalForAll(address indexed owner, address indexed operator, bool approved);
    event NFTBurned(address indexed owner, uint256 indexed tokenId);

    function initialize(address _primaryStablecoin, address _goldPriceFeed, address _treasury, uint256 initialReserve, uint8 _decimals) public initializer {
        require(_primaryStablecoin != address(0), "Invalid stablecoin address");
        require(_goldPriceFeed != address(0), "Invalid price feed address");
        require(_treasury != address(0), "Invalid treasury address");
        require(_decimals > 0 && _decimals <= 18, "Invalid decimals");
        __ReentrancyGuard_init();
        __UUPSUpgradeable_init();
        __Ownable_init();
        primaryStablecoin = IERC20Upgradeable(_primaryStablecoin);
        goldPriceFeed = AggregatorV3Interface(_goldPriceFeed);
        treasury = _treasury;
        stablecoinDecimals[_primaryStablecoin] = _decimals;
        if (initialReserve > 0) {
            require(IERC20Upgradeable(primaryStablecoin).transferFrom(msg.sender, address(this), initialReserve), "Initial reserve transfer failed");
            reserveBalances[address(primaryStablecoin)] = initialReserve * 8 / 10;
            merchantIncentivePools[_primaryStablecoin] = initialReserve * 2 / 10;
        }
        supportedStablecoins.push(_primaryStablecoin);
        isSupportedStablecoin[_primaryStablecoin] = true;
    }

    function fundReserves(address stablecoin, uint256 amount) external onlyOwner {
        require(amount > 0, "Amount must be greater than 0");
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        require(IERC20Upgradeable(stablecoin).transferFrom(msg.sender, address(this), amount), "Reserve funding failed");
        reserveBalances[stablecoin] += amount * 8 / 10;
        merchantIncentivePools[stablecoin] += amount * 2 / 10;
        emit ReservesFunded(msg.sender, amount, stablecoin);
    }

    function _authorizeUpgrade(address newImplementation) internal override onlyOwner {
        emit ContractUpgraded(newImplementation);
    }

    modifier whenNotPaused() { require(!paused, "Contract is paused"); _; }

    function transfer(address to, uint256 amount) public whenNotPaused returns (bool) {
        _transfer(msg.sender, to, amount);
        return true;
    }

    function transferFrom(address from, address to, uint256 amount) public whenNotPaused returns (bool) {
        require(_allowances[from][msg.sender] >= amount, "Insufficient allowance");
        _allowances[from][msg.sender] -= amount;
        _transfer(from, to, amount);
        return true;
    }

    function approve(address spender, uint256 amount) public whenNotPaused returns (bool) {
        _allowances[msg.sender][spender] = amount;
        emit Approval(msg.sender, spender, amount);
        return true;
    }

    function allowance(address owner, address spender) public view returns (uint256) {
        return _allowances[owner][spender];
    }

    /// @notice Purchase ADC with any registered stablecoin.
    function buyWithStablecoin(address stablecoin, uint256 amount) external nonReentrant whenNotPaused {
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        uint256 basePrice = getBasePrice();
        uint256 scaledAmount = _scaleToBase(amount, stablecoinDecimals[stablecoin]);
        require(scaledAmount >= (MIN_PURCHASE * basePrice) / PRECISION, "Below minimum purchase");
        uint256 adcToMint = (scaledAmount * PRECISION) / basePrice;
        require(_totalSupply + adcToMint <= INITIAL_MAX_SUPPLY, "Exceeds max supply");
        require(IERC20Upgradeable(stablecoin).transferFrom(msg.sender, address(this), amount), "Stablecoin transfer failed");
        reserveBalances[stablecoin] += amount * 8 / 10;
        merchantIncentivePools[stablecoin] += amount * 2 / 10;
        _mintADC(msg.sender, adcToMint);
        uint256 tokenId = tokenIdCounter++;
        _mintNFT(msg.sender, tokenId);
        emit Purchased(msg.sender, amount, adcToMint, stablecoin);
        emit CertificateOfOwnership(msg.sender, adcToMint, tokenId);
    }

    function transferNoFee(address to, uint256 amount) external whenNotPaused {
        require(_nftBalances[msg.sender] > 0 && _nftBalances[to] > 0, "Both parties must hold NFTs");
        require(_balances[msg.sender] >= amount, "Insufficient balance");
        _transfer(msg.sender, to, amount);
        emit TransferNoFee(msg.sender, to, amount);
    }

    function claimGasSubsidy() external whenNotPaused {
        require(gasSubsidyPool >= gasSubsidyRate, "Insufficient gas subsidy pool");
        gasSubsidyPool -= gasSubsidyRate;
        require(IERC20Upgradeable(primaryStablecoin).transfer(msg.sender, gasSubsidyRate), "Gas subsidy transfer failed");
        emit GasSubsidyClaimed(msg.sender, gasSubsidyRate);
    }

    function swapADCForStablecoin(uint256 adcAmount, address stablecoin) external whenNotPaused {
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        require(_nftBalances[msg.sender] > 0 && _balances[msg.sender] >= adcAmount, "Insufficient ADC or NFT balance");
        uint256 stablecoinAmount = _scaleFromBase(adcAmount, getBasePrice(), stablecoinDecimals[stablecoin]);
        require(liquidityPool[stablecoin] >= stablecoinAmount, "Insufficient liquidity");
        _burnADC(msg.sender, adcAmount);
        liquidityPool[stablecoin] -= stablecoinAmount;
        require(IERC20Upgradeable(stablecoin).transfer(msg.sender, stablecoinAmount), "Stablecoin transfer failed");
        emit SwapExecuted(msg.sender, adcAmount, stablecoinAmount, stablecoin);
    }

    function addLiquidity(address stablecoin, uint256 amount) external whenNotPaused {
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        require(amount > 0, "Amount must be > 0");
        require(IERC20Upgradeable(stablecoin).transferFrom(msg.sender, address(this), amount), "Liquidity transfer failed");
        liquidityPool[stablecoin] += amount;
        emit LiquidityAdded(msg.sender, stablecoin, amount);
    }

    /// @notice Add a supported stablecoin (owner-only).
    function addSupportedStablecoin(address stablecoin, uint8 decimals_) external onlyOwner {
        require(stablecoin != address(0), "Invalid stablecoin");
        require(!isSupportedStablecoin[stablecoin], "Already supported");
        require(supportedStablecoins.length < MAX_SUPPORTED_STABLECOINS, "Max stablecoins reached");
        require(decimals_ > 0 && decimals_ <= 18, "Invalid decimals");
        supportedStablecoins.push(stablecoin);
        isSupportedStablecoin[stablecoin] = true;
        stablecoinDecimals[stablecoin] = decimals_;
    }

    function redeemADC(uint256 adcAmount, address stablecoin) external nonReentrant whenNotPaused {
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        uint256 currentDay = block.timestamp / 86400;
        if (lastRedemptionReset[msg.sender] / 86400 != currentDay) {
            dailyRedemptionVolume[msg.sender][currentDay] = 0;
            lastRedemptionReset[msg.sender] = block.timestamp;
        }
        require(adcAmount <= DAILY_REDEMPTION_LIMIT && _balances[msg.sender] >= adcAmount, "Exceeds redemption limit or balance");
        require(dailyRedemptionVolume[msg.sender][currentDay] + adcAmount <= DAILY_REDEMPTION_LIMIT, "Exceeds daily limit");
        dailyRedemptionVolume[msg.sender][currentDay] += adcAmount;
        uint256 reserveValue = getTotalReserveValue();
        uint256 basePrice = _getBasePriceWithReserve(reserveValue);
        uint256 stablecoinValue = _scaleFromBase(adcAmount, basePrice, stablecoinDecimals[stablecoin]);
        require(reserveBalances[stablecoin] >= stablecoinValue && _getReserveHealth(reserveValue, basePrice) >= RESERVE_THRESHOLD, "Insufficient reserves or health");
        _burnADC(msg.sender, adcAmount);
        reserveBalances[stablecoin] -= stablecoinValue;
        require(IERC20Upgradeable(stablecoin).transfer(msg.sender, stablecoinValue), "Redemption transfer failed");
        emit Redemption(msg.sender, adcAmount, stablecoinValue);
    }

    function batchAddMerchants(address[] calldata merchants) external onlyOwner {
        uint256 len = merchants.length;
        require(len <= 100, "Too many merchants");
        for (uint256 i = 0; i < len; ) {
            whitelistedMerchants[merchants[i]] = true;
            emit MerchantAdded(merchants[i]);
            unchecked { ++i; }
        }
    }

    function claimMerchantBonus() external whenNotPaused {
        require(whitelistedMerchants[msg.sender], "Not a whitelisted merchant");
        require(merchantBonusClaimed < MAX_MERCHANT_BONUSES, "Max bonuses claimed");
        require(_totalSupply + MERCHANT_BONUS <= INITIAL_MAX_SUPPLY, "Exceeds max supply");
        merchantBonusClaimed++;
        _mintADC(msg.sender, MERCHANT_BONUS);
        emit MerchantBonusClaimed(msg.sender, MERCHANT_BONUS);
    }

    function paymentToMerchant(address merchant, uint256 amount, uint256 tokenId, address stablecoin) external whenNotPaused {
        require(whitelistedMerchants[merchant] && _owners[tokenId] == msg.sender, "Invalid merchant or token ownership");
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        uint256 maxPayment = (getTotalReserveValue() * MAX_PAYMENT_CAP) / PRECISION;
        require(amount <= maxPayment, "Exceeds max payment cap");
        uint256 fee = (amount * MERCHANT_PAYMENT_FEE) / PRECISION;
        uint256 netAmount = amount - fee;
        require(_balances[msg.sender] >= amount, "Insufficient balance");
        _transfer(msg.sender, merchant, netAmount);
        _distributeFees(fee);
        uint256 incentive = (netAmount * MERCHANT_INCENTIVE_RATE) / PRECISION;
        if (merchantIncentivePools[stablecoin] >= incentive) {
            merchantIncentivePools[stablecoin] -= incentive;
            require(IERC20Upgradeable(stablecoin).transfer(merchant, incentive), "Incentive transfer failed");
        }
        emit MerchantPayment(msg.sender, merchant, netAmount, tokenId);
    }

    function createGiftVoucher(uint256 amount, address to, address stablecoin) external whenNotPaused {
        require(_nftBalances[msg.sender] > 0, "Must hold an NFT");
        if (amount > 0) {
            require(_balances[msg.sender] >= amount, "Insufficient ADC balance");
            _burnADC(msg.sender, amount);
        } else {
            amount = 50e6;
            require(IERC20Upgradeable(stablecoin).transferFrom(msg.sender, address(this), amount), "Stablecoin transfer failed");
            voucherStablecoin[voucherIdCounter] = stablecoin;
        }
        voucherAmounts[voucherIdCounter] = amount;
        _mintVoucher(to, voucherIdCounter);
        emit GiftVoucherCreated(voucherIdCounter, msg.sender, to, amount);
        voucherIdCounter++;
    }

    function redeemVoucher(uint256 voucherId) external nonReentrant whenNotPaused {
        require(voucherAmounts[voucherId] > 0 && _owners[voucherId] == msg.sender, "Invalid voucher or ownership");
        uint256 amount = voucherAmounts[voucherId];
        address stablecoin = voucherStablecoin[voucherId];
        // CEI: clear state before external interactions
        voucherAmounts[voucherId] = 0;
        uint256 tokenId = tokenIdCounter++;
        _mintNFT(msg.sender, tokenId);
        if (stablecoin == address(0)) _mintADC(msg.sender, amount);
        else require(IERC20Upgradeable(stablecoin).transfer(msg.sender, amount), "Voucher redemption transfer failed");
        emit CertificateOfOwnership(msg.sender, amount, tokenId);
        emit VoucherRedeemed(voucherId, msg.sender, amount);
    }

    function lendToUser(address borrower, uint256 amount, uint256 tokenId) external nonReentrant whenNotPaused {
        require(_nftBalances[msg.sender] > 0 && _nftBalances[borrower] > 0, "Both parties must hold NFTs");
        require(_balances[msg.sender] >= amount && _owners[tokenId] == borrower, "Insufficient balance or token ownership");
        require(!stakedNFTs[tokenId].isStaked && p2pLoans[borrower].amount == 0, "NFT staked or loan exists");
        _transfer(msg.sender, borrower, amount);
        p2pLoans[borrower] = P2PLoan(msg.sender, amount, amount * 10e16 / PRECISION, block.timestamp, tokenId, false);
        stakedNFTs[tokenId] = Stake(true, block.timestamp, 0);
        emit P2PLoanCreated(msg.sender, borrower, amount, tokenId);
    }

    function repayLoan() external nonReentrant whenNotPaused {
        P2PLoan memory loan = p2pLoans[msg.sender];
        require(loan.amount > 0 && !loan.repaid, "No active loan");
        uint256 totalRepayment = loan.amount + (loan.interest * (block.timestamp - loan.startTime)) / SECONDS_PER_YEAR;
        require(_balances[msg.sender] >= totalRepayment, "Insufficient balance");
        p2pLoans[msg.sender].repaid = true;
        delete stakedNFTs[loan.tokenId];
        _transfer(msg.sender, loan.lender, totalRepayment);
        emit P2PLoanRepaid(msg.sender, loan.lender, totalRepayment);
    }

    /// @notice Liquidate an expired loan. If the borrower hasn't repaid within
    ///         LOAN_MAX_DURATION, the lender can claim the collateral NFT.
    function liquidateLoan(address borrower) external whenNotPaused {
        P2PLoan memory loan = p2pLoans[borrower];
        require(loan.amount > 0 && !loan.repaid, "No active loan");
        require(msg.sender == loan.lender, "Only lender can liquidate");
        require(block.timestamp >= loan.startTime + LOAN_MAX_DURATION, "Loan not yet expired");
        // Transfer NFT collateral to lender
        _transferNFTInternal(borrower, loan.lender, loan.tokenId);
        delete stakedNFTs[loan.tokenId];
        p2pLoans[borrower].repaid = true;
        emit P2PLoanLiquidated(loan.lender, borrower, loan.tokenId);
    }

    function stakeNFT(uint256 tokenId, uint256 amount) external nonReentrant whenNotPaused {
        require(_owners[tokenId] == msg.sender && !stakedNFTs[tokenId].isStaked, "Invalid ownership or already staked");
        uint256 reserveValue = getTotalReserveValue();
        uint256 basePrice = _getBasePriceWithReserve(reserveValue);
        require(_balances[msg.sender] >= amount && _getReserveHealth(reserveValue, basePrice) >= RESERVE_THRESHOLD, "Insufficient balance or reserve health");
        _transfer(msg.sender, address(this), amount);
        stakedNFTs[tokenId] = Stake(true, block.timestamp, amount);
        emit NFTStaked(msg.sender, tokenId, amount);
    }

    function unstakeNFT(uint256 tokenId) external nonReentrant whenNotPaused {
        require(_owners[tokenId] == msg.sender && stakedNFTs[tokenId].isStaked, "Invalid ownership or not staked");
        Stake memory stake = stakedNFTs[tokenId];
        uint256 reward = calculateNFTStakingReward(tokenId);
        delete stakedNFTs[tokenId];
        if (reward > 0 && _totalSupply + reward <= INITIAL_MAX_SUPPLY) {
            _mintADC(msg.sender, reward);
        }
        _transfer(address(this), msg.sender, stake.amount);
        emit NFTUnstaked(msg.sender, tokenId, reward);
    }

    /// @notice Claim passive reward for an NFT. Reward is based on the NFT's
    ///         purchase amount (recorded at mint time via CertificateOfOwnership),
    ///         not the user's total balance, to prevent multi-NFT exploit.
    function claimPassiveReward(uint256 tokenId) external nonReentrant whenNotPaused {
        require(_owners[tokenId] == msg.sender, "Not token owner");
        require(!stakedNFTs[tokenId].isStaked, "NFT is staked");
        uint256 timeHeld = block.timestamp - nftMintTime[tokenId];
        // Use a fixed per-NFT base value to prevent exploit where user claims
        // on multiple NFTs using entire balance
        uint256 reward = (NFT_BASE_VALUE * BASE_PASSIVE_YIELD * timeHeld) / (SECONDS_PER_YEAR * PRECISION);
        require(_totalSupply + reward <= INITIAL_MAX_SUPPLY, "Exceeds max supply");
        nftMintTime[tokenId] = block.timestamp;
        _mintADC(msg.sender, reward);
        emit NFTRewardClaimed(msg.sender, tokenId, reward);
    }

    function calculateNFTStakingReward(uint256 tokenId) public view returns (uint256) {
        Stake memory stake = stakedNFTs[tokenId];
        if (!stake.isStaked) return 0;
        uint256 timeStaked = block.timestamp - stake.stakeTime;
        return (stake.amount * BASE_NFT_YIELD * timeStaked) / (SECONDS_PER_YEAR * PRECISION);
    }

    function getBasePrice() public view returns (uint256) {
        return _getBasePriceWithReserve(getTotalReserveValue());
    }

    function getTotalReserveValue() public view returns (uint256) {
        uint256 total = 0;
        uint256 len = supportedStablecoins.length;
        for (uint256 i = 0; i < len; ) {
            total += reserveBalances[supportedStablecoins[i]];
            unchecked { ++i; }
        }
        return total;
    }

    function getReserveHealth() public view returns (uint256) {
        uint256 reserveValue = getTotalReserveValue();
        uint256 basePrice = _getBasePriceWithReserve(reserveValue);
        return _getReserveHealth(reserveValue, basePrice);
    }

    function _getBasePriceWithReserve(uint256 totalReserveValue) internal view returns (uint256) {
        (, int256 goldPrice,, uint256 updatedAt,) = goldPriceFeed.latestRoundData();
        require(goldPrice > 0, "Invalid gold price");
        require(block.timestamp <= updatedAt + ORACLE_STALENESS_THRESHOLD, "Oracle data stale");
        uint256 goldBase = uint256(goldPrice) * 16;
        if (totalReserveValue == 0 || _totalSupply == 0) return goldBase;
        return (goldBase * totalReserveValue * 10**2 * PRECISION) / (_totalSupply * PRECISION);
    }

    function _getReserveHealth(uint256 totalReserveValue, uint256 basePrice) internal view returns (uint256) {
        uint256 supplyValue = (_totalSupply * basePrice) / PRECISION / 10**2;
        return supplyValue > 0 ? (totalReserveValue * PRECISION / supplyValue) : PRECISION;
    }

    /// @notice Scale a stablecoin amount to 8-decimal base representation.
    ///         For 6-decimal tokens: amount * 10**2 = 8-digit base.
    ///         For 18-decimal tokens: amount / 10**10 = 8-digit base.
    function _scaleToBase(uint256 amount, uint8 tokenDecimals) internal pure returns (uint256) {
        require(tokenDecimals > 0 && tokenDecimals <= 18, "Invalid decimals");
        if (tokenDecimals <= 8) {
            return amount * (10 ** (8 - tokenDecimals));
        } else {
            return amount / (10 ** (tokenDecimals - 8));
        }
    }

    /// @notice Convert ADC amount (18 decimals) at basePrice into stablecoin-native units.
    function _scaleFromBase(uint256 adcAmount, uint256 basePrice, uint8 tokenDecimals) internal pure returns (uint256) {
        require(tokenDecimals > 0 && tokenDecimals <= 18, "Invalid decimals");
        // First compute value in 8-decimal base: (adcAmount * basePrice) / PRECISION
        // Then convert to token-native decimals
        uint256 baseValue = (adcAmount * basePrice) / PRECISION;
        if (tokenDecimals <= 8) {
            return baseValue / (10 ** (8 - tokenDecimals));
        } else {
            return baseValue * (10 ** (tokenDecimals - 8));
        }
    }

    /// @notice Update the primary stablecoin used for gas subsidies (owner-only).
    function setPrimaryStablecoin(address stablecoin) external onlyOwner {
        require(isSupportedStablecoin[stablecoin], "Unsupported stablecoin");
        address old = address(primaryStablecoin);
        primaryStablecoin = IERC20Upgradeable(stablecoin);
        emit PrimaryStablecoinUpdated(old, stablecoin);
    }

    function _mintADC(address to, uint256 value) internal {
        _totalSupply += value;
        _balances[to] += value;
    }

    function _burnADC(address account, uint256 amount) internal {
        require(_balances[account] >= amount, "Insufficient balance to burn");
        _balances[account] -= amount;
        _totalSupply -= amount;
    }

    function _transfer(address from, address to, uint256 amount) internal {
        require(_balances[from] >= amount, "Insufficient balance");
        _balances[from] -= amount;
        _balances[to] += amount;
    }

    function _mintNFT(address to, uint256 tokenId) internal {
        require(nftTotalSupply < MAX_NFT_SUPPLY, "NFT supply cap reached");
        _nftBalances[to]++;
        _owners[tokenId] = to;
        nftMintTime[tokenId] = block.timestamp;
        nftTotalSupply++;
        emit NFTTransfer(address(0), to, tokenId);
    }

    function _mintVoucher(address to, uint256 voucherId) internal {
        _nftBalances[to]++;
        _owners[voucherId] = to;
    }

    function _distributeFees(uint256 fee) internal {
        uint256 subsidyShare = fee * 20e16 / PRECISION;
        gasSubsidyPool += subsidyShare;
        if (gasSubsidyPool > MAX_GAS_POOL) gasSubsidyPool = MAX_GAS_POOL;
        feePool += (fee - subsidyShare);
    }

    // =========================================================================
    //                      NFT TRANSFER & APPROVAL
    // =========================================================================

    /// @notice Transfer an NFT to another address. Cannot transfer staked NFTs.
    function transferNFT(address to, uint256 tokenId) external whenNotPaused {
        require(to != address(0), "Transfer to zero address");
        require(_isApprovedOrOwner(msg.sender, tokenId), "Not owner or approved");
        require(!stakedNFTs[tokenId].isStaked, "Cannot transfer staked NFT");
        _transferNFTInternal(_owners[tokenId], to, tokenId);
    }

    /// @notice Approve an address to manage a specific NFT.
    function approveNFT(address to, uint256 tokenId) external whenNotPaused {
        address tokenOwner = _owners[tokenId];
        require(tokenOwner != address(0), "Token does not exist");
        require(msg.sender == tokenOwner || _operatorApprovals[tokenOwner][msg.sender], "Not owner or operator");
        require(to != tokenOwner, "Approval to current owner");
        _nftApprovals[tokenId] = to;
        emit NFTApproval(tokenOwner, to, tokenId);
    }

    /// @notice Set or revoke operator approval for all of caller's NFTs.
    function setApprovalForAll(address operator, bool approved) external whenNotPaused {
        require(operator != msg.sender, "Approve to caller");
        _operatorApprovals[msg.sender][operator] = approved;
        emit NFTApprovalForAll(msg.sender, operator, approved);
    }

    /// @notice Get the approved address for a single NFT.
    function getApproved(uint256 tokenId) public view returns (address) {
        require(_owners[tokenId] != address(0), "Token does not exist");
        return _nftApprovals[tokenId];
    }

    /// @notice Check if an operator is approved for all of an owner's NFTs.
    function isApprovedForAll(address owner, address operator) public view returns (bool) {
        return _operatorApprovals[owner][operator];
    }

    /// @notice Burn an NFT. Only the owner can burn. Cannot burn staked NFTs.
    function burnNFT(uint256 tokenId) external whenNotPaused {
        require(_owners[tokenId] == msg.sender, "Not token owner");
        require(!stakedNFTs[tokenId].isStaked, "Cannot burn staked NFT");
        _nftBalances[msg.sender]--;
        delete _owners[tokenId];
        delete _nftApprovals[tokenId];
        delete nftMintTime[tokenId];
        nftTotalSupply--;
        emit NFTBurned(msg.sender, tokenId);
        emit NFTTransfer(msg.sender, address(0), tokenId);
    }

    function _transferNFTInternal(address from, address to, uint256 tokenId) internal {
        _nftBalances[from]--;
        _nftBalances[to]++;
        _owners[tokenId] = to;
        delete _nftApprovals[tokenId];
        emit NFTTransfer(from, to, tokenId);
    }

    function _isApprovedOrOwner(address spender, uint256 tokenId) internal view returns (bool) {
        address tokenOwner = _owners[tokenId];
        require(tokenOwner != address(0), "Token does not exist");
        return (spender == tokenOwner || _nftApprovals[tokenId] == spender || _operatorApprovals[tokenOwner][spender]);
    }

    // =========================================================================
    //                      ERC165 & METADATA
    // =========================================================================

    /// @notice Set the base URI for NFT metadata (owner-only).
    function setBaseTokenURI(string calldata _baseURI) external onlyOwner {
        baseTokenURI = _baseURI;
    }

    /// @notice Returns the metadata URI for a given NFT token.
    function tokenURI(uint256 tokenId) external view returns (string memory) {
        require(_owners[tokenId] != address(0), "Token does not exist");
        return string(abi.encodePacked(baseTokenURI, _toString(tokenId)));
    }

    /// @notice ERC-165 interface detection.
    function supportsInterface(bytes4 interfaceId) external pure returns (bool) {
        return interfaceId == INTERFACE_ID_ERC165 || interfaceId == INTERFACE_ID_ERC721;
    }

    // =========================================================================
    //                          VIEW FUNCTIONS
    // =========================================================================

    function name() public pure returns (string memory) { return "American Digital Currency"; }
    function symbol() public pure returns (string memory) { return "ADC"; }
    function decimals() public pure returns (uint8) { return 18; }

    function balanceOf(address account) public view returns (uint256) { return _balances[account]; }
    function totalSupply() public view returns (uint256) { return _totalSupply; }
    function ownerOf(uint256 tokenId) public view returns (address) {
        address owner = _owners[tokenId];
        require(owner != address(0), "Token does not exist");
        return owner;
    }
    function balanceOfNFT(address owner) public view returns (uint256) { return _nftBalances[owner]; }

    /// @dev Convert uint256 to decimal string.
    function _toString(uint256 value) internal pure returns (string memory) {
        if (value == 0) return "0";
        uint256 temp = value;
        uint256 digits;
        while (temp != 0) {
            digits++;
            temp /= 10;
        }
        bytes memory buffer = new bytes(digits);
        while (value != 0) {
            digits--;
            buffer[digits] = bytes1(uint8(48 + (value % 10)));
            value /= 10;
        }
        return string(buffer);
    }
}
